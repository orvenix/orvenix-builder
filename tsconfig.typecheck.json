{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "types/**/*.ts",
    "types/**/*.tsx",
    "generated/**/*.ts",
    "generated/**/*.tsx",
    "blocks/**/*.ts",
    "blocks/**/*.tsx",
    "store/**/*.ts",
    "store/**/*.tsx",
    "templates/**/*.ts",
    "templates/**/*.tsx",
    "emails/**/*.ts",
    "emails/**/*.tsx",
    "proxy.ts",
    "next.config.ts",
    "prisma.config.ts",
    "instrumentation-client.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".tmp",
    "tests",
    ".next/dev"
  ]
}
