



{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run vercel-build",
  "regions": ["iad1"],
  "functions": {
    "app/api/editor/upload/route.ts": {
      "maxDuration": 30
    },
    "app/api/editor/[id]/export/route.ts": {
      "maxDuration": 60
    },
    "app/api/chat/route.ts": {
      "maxDuration": 30
    }
  }
}
