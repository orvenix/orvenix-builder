# ============================================================================
# VARIABLES DE ENTORNO — PLANTILLA COMPLETA
# ============================================================================
# Copia este archivo a .env.local para desarrollo o .env.production para prod.
# NUNCA subas archivos .env* a Git.
# ============================================================================

# ─── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV="production"

# ─── Persistencia ─────────────────────────────────────────────────────────────
# "file"   → guarda en data/runtime-store.json (sin DB externa, ideal para inicio)
# "prisma" → usa MariaDB/MySQL vía DATABASE_URL
ORVENIX_STORAGE_MODE="prisma"

# ─── Base de datos MySQL/MariaDB (solo si ORVENIX_STORAGE_MODE=prisma) ────────
DATABASE_URL="mysql://orvenix_user:PASSWORD_SEGURO@localhost:3306/orvenix_saas"

# ─── NextAuth (REQUERIDO) ─────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
AUTH_SECRET="REEMPLAZAR_CON_32_BYTES_RANDOM_HEX"
NEXTAUTH_SECRET="REEMPLAZAR_CON_32_BYTES_RANDOM_HEX"

# URL pública de la app (sin trailing slash):
NEXTAUTH_URL="https://orvenix.com.mx"
AUTH_URL="https://orvenix.com.mx"

# Correos separados por coma con rol ADMIN:
ORVENIX_ADMIN_EMAILS="tu@correo.com"

# ─── URLs públicas ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://orvenix.com.mx"

# Opcional: sitio que recibirá automatizaciones desde el formulario público /contacto
# cuando el formulario no tenga contexto de un sitio específico.
ORVENIX_MARKETING_SITE_ID=""
NEXT_PUBLIC_ORVENIX_MARKETING_SITE_ID=""

# ─── Email transaccional · Resend ─────────────────────────────────────────────
# Cuenta en: https://resend.com (plan gratis: 3,000/mes)
# 1. Crea API key en dashboard.resend.com/api-keys
# 2. Verifica dominio en dashboard.resend.com/domains
RESEND_API_KEY="re_placeholder"
RESEND_FROM="Orvenix <hola@orvenix.com.mx>"

# ─── Pagos · MercadoPago ─────────────────────────────────────────────────────
# Usar para checkout de tienda / pagos únicos. No es la pasarela principal
# para suscripciones nuevas en el estado actual del proyecto.
# Crea tu cuenta en: https://www.mercadopago.com.mx/developers/
# Panel: https://www.mercadopago.com.mx/developers/panel/app
#
# 1. Crea una aplicación en el panel de desarrolladores
# 2. Obtén las credenciales de PRODUCCIÓN (no las de prueba)
# 3. Configura el webhook en: Panel → Tu App → Webhooks
#    URL: https://orvenix.com.mx/api/checkout/webhook
#    Eventos: payments
#
# Access Token de producción (empieza con APP_USR-...):
MP_ACCESS_TOKEN="APP_USR-placeholder"

# Public Key (para uso en frontend si fuera necesario):
MP_PUBLIC_KEY="APP_USR-placeholder-public"

# En producción debe ser "false". En local puedes usar "true".
MP_SANDBOX="false"

# ─── Pagos · Stripe ──────────────────────────────────────────────────────────
# Pasarela principal para suscripciones nuevas. Usa llaves de prueba en
# desarrollo y llaves de producción al lanzar. No compartas ni subas el secret key.
#
# 1. Crea productos y precios recurrentes en Stripe Dashboard.
# 2. Copia los Price IDs (empiezan con price_...) en las variables por plan.
# 3. Configura el webhook:
#    URL: https://orvenix.com.mx/api/billing/stripe-webhook
#    Eventos: checkout.session.completed, customer.subscription.created,
#             customer.subscription.updated, customer.subscription.deleted
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_placeholder"
STRIPE_SECRET_KEY="sk_live_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"

STRIPE_PRICE_STARTER_MONTH="price_placeholder"
STRIPE_PRICE_STARTER_YEAR="price_placeholder"
STRIPE_PRICE_PRO_MONTH="price_placeholder"
STRIPE_PRICE_PRO_YEAR="price_placeholder"
STRIPE_PRICE_COMMERCE_MONTH="price_placeholder"
STRIPE_PRICE_COMMERCE_YEAR="price_placeholder"

# ─── IA · Anthropic Claude ────────────────────────────────────────────────────
# Necesario para el chatbot del sitio. Obtén key en console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-placeholder"

# ─── Notas operativas de deploy ───────────────────────────────────────────────
# Si la base productiva ya existía antes de versionar migraciones Prisma:
# 1. npm run prisma:resolve-baseline
# 2. npm run prisma:deploy-schema
#
# Si la base es completamente nueva:
# 1. npm run prisma:deploy-schema

# ─── Logging (opcional) ───────────────────────────────────────────────────────
# DEBUG=* para todos los logs. Vacío en producción.
DEBUG=""
